  function ensureCheckbox(itemEl) {
    if (itemEl.dataset.tmBulkReady === '1') return;
    itemEl.dataset.tmBulkReady = '1';

    const row = getItemRow(itemEl);
    if (!row) return;

    const handle = row.querySelector('.ig-handle');

    const cell = document.createElement('div');
    cell.className = CLASSES.checkboxCell;

    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = CLASSES.checkbox;
    cb.title = `Select ${getItemTitle(itemEl)}`;

    cb.addEventListener('change', () => {
      row.classList.toggle(CLASSES.selectedRow, cb.checked);
      const moduleEl = itemEl.closest(SEL.module);
      if (moduleEl) updateToolbarState(moduleEl);
    });

    cell.appendChild(cb);

    if (handle && handle.nextSibling) {
      row.insertBefore(cell, handle.nextSibling);
    } else {
      row.insertBefore(cell, row.firstChild);
    }
  }

  function setItemChecked(itemEl, checked) {
    const cb = itemEl.querySelector(`.${CLASSES.checkbox}`);
    const row = getItemRow(itemEl);
    if (!cb || !row) return;
    cb.checked = checked;
    row.classList.toggle(CLASSES.selectedRow, checked);
  }

  function clearSelections(moduleEl) {
    getVisibleItems(moduleEl).forEach(item => setItemChecked(item, false));
    updateToolbarState(moduleEl);
  }

  function selectAllItems(moduleEl) {
    getVisibleItems(moduleEl).forEach(item => setItemChecked(item, true));
    updateToolbarState(moduleEl);
  }

  function ensureToolbar(moduleEl) {
    const content = $(SEL.content, moduleEl);
    const list = $(SEL.itemList, moduleEl);
    if (!content || !list) return null;

    let wrap = content.querySelector(`.${CLASSES.toolbarWrap}`);
    if (wrap) return wrap;

    wrap = document.createElement('div');
    wrap.className = `${CLASSES.toolbarWrap} ${CLASSES.hidden}`;

    const toolbar = document.createElement('div');
    toolbar.className = CLASSES.toolbar;
    toolbar.setAttribute('role', 'toolbar');
    toolbar.setAttribute('aria-label', 'Bulk item actions');

    const makeButton = (label, attrs = {}) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = CLASSES.button;
      btn.textContent = label;
      Object.entries(attrs).forEach(([k, v]) => btn.setAttribute(k, v));
      return btn;
    };

    const selectAllBtn = makeButton('Select All', { 'data-bulk-control': 'select-all' });
    selectAllBtn.addEventListener('click', () => selectAllItems(moduleEl));
    toolbar.appendChild(selectAllBtn);

    ACTIONS.forEach(action => {
      const btn = makeButton(action.label, { 'data-bulk-action': action.key });
      if (action.key === 'remove') btn.classList.add(CLASSES.buttonDanger);

      btn.addEventListener('click', () => {
        if (btn.disabled) return;
        runBulkAction(moduleEl, action.key);
      });

      toolbar.appendChild(btn);
    });

    const clearBtn = makeButton('Unselect All', { 'data-bulk-control': 'clear' });
    clearBtn.addEventListener('click', () => clearSelections(moduleEl));
    toolbar.appendChild(clearBtn);

    const count = document.createElement('span');
    count.className = CLASSES.count;
    toolbar.appendChild(count);

    wrap.appendChild(toolbar);
    content.insertBefore(wrap, list);

    return wrap;
  }

  function updateToolbarState(moduleEl) {
    const wrap = ensureToolbar(moduleEl);
    if (!wrap) return;

    const selectedItems = getSelectedItems(moduleEl);
    const count = selectedItems.length;
    const totalItems = getVisibleItems(moduleEl).length;
    const commonActions = getCommonActions(selectedItems);

    wrap.classList.toggle(CLASSES.hidden, count === 0);

    const countEl = wrap.querySelector(`.${CLASSES.count}`);
    const clearBtn = wrap.querySelector('[data-bulk-control="clear"]');
    const selectAllBtn = wrap.querySelector('[data-bulk-control="select-all"]');

    if (countEl) {
      countEl.textContent = `${count} selected`;
    }

    if (clearBtn) {
      clearBtn.classList.toggle(CLASSES.hidden, count === 0);
    }

    if (selectAllBtn) {
      const hideSelectAll = count === 0 || totalItems === 0 || count === totalItems;
      selectAllBtn.classList.toggle(CLASSES.hidden, hideSelectAll);
      selectAllBtn.disabled = hideSelectAll;
      selectAllBtn.classList.toggle(CLASSES.buttonDisabled, selectAllBtn.disabled);
    }

    wrap.querySelectorAll('[data-bulk-action]').forEach(btn => {
      const action = ACTIONS.find(a => a.key === btn.dataset.bulkAction);
      const enabled = count > 0 && commonActions.some(a => a.key === action.key);
      btn.disabled = !enabled;
      btn.classList.toggle(CLASSES.buttonDisabled, !enabled);
    });
  }

  function refreshUI() {
    getVisibleModules().forEach(moduleEl => {
      getVisibleItems(moduleEl).forEach(ensureCheckbox);
      ensureToolbar(moduleEl);
      updateToolbarState(moduleEl);
    });
  }

  function init() {
    injectStyles();
    refreshUI();

    const observer = new MutationObserver(debounce(() => {
      refreshUI();
    }, 120));

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

    log('Initialized');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
