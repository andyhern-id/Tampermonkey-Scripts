// ==UserScript==
// @name         Canvas Bulk Item Actions (clean toolbar)
// @namespace    https://tampermonkey.net/
// @version      1.2.0
// @description  Bulk actions for Canvas module items with inline toolbar, select all, reliable move/duplicate/indent/remove.
// @author Andy Hernandez
// @match        https://*/courses/*/modules*
// @match        http://*/courses/*/modules*
// @grant        none
// ==/UserScript==

(function () {
  'use strict';

  const CONFIG = {
    debug: false,
    actionDelayMs: 180
  };

  const SEL = {
    module: '.context_module.item-group-condensed',
    content: '.content',
    itemList: 'ul.context_module_items.manageable, ul.ig-list.items.context_module_items',
    item: 'li.context_module_item',
    itemRow: '.ig-row',
    itemTitle: '.module-item-title .item_name .title, .module-item-title .item_name a, .module-item-title .title',
    itemMenu: '.cog-menu-container .al-options',
    itemType: '.module_item_icons .type',
    itemUrl: '.module-item-title .url',
    itemNewTab: '.module-item-title .new_tab'
  };

  const CLASSES = {
    checkboxCell: 'tm-bulk-checkbox-cell',
    checkbox: 'tm-bulk-checkbox',
    selectedRow: 'tm-bulk-selected-row',
    toolbarWrap: 'tm-bulk-toolbar-wrap',
    toolbar: 'tm-bulk-toolbar',
    button: 'tm-bulk-button',
    buttonDanger: 'tm-bulk-button-danger',
    buttonDisabled: 'tm-bulk-button-disabled',
    count: 'tm-bulk-count',
    hidden: 'tm-bulk-hidden',

    modalOverlay: 'tm-bulk-modal-overlay',
    modal: 'tm-bulk-modal',
    modalTitle: 'tm-bulk-modal-title',
    modalSubtext: 'tm-bulk-modal-subtext',
    modalList: 'tm-bulk-modal-list',
    modalOption: 'tm-bulk-modal-option',
    modalOptionTitle: 'tm-bulk-modal-option-title',
    modalOptionMeta: 'tm-bulk-modal-option-meta',
    modalFooter: 'tm-bulk-modal-footer'
  };

  const ACTIONS = [
    { key: 'move', selector: 'a.move_module_item_link', mode: 'move', label: 'Move To…' },
    { key: 'duplicate', selector: 'a.duplicate_item_link', mode: 'duplicate', label: 'Duplicate' },
    { key: 'outdent', selector: 'a.outdent_item_link', mode: 'indent', label: 'Decrease indent' },
    { key: 'indent', selector: 'a.indent_item_link', mode: 'indent', label: 'Increase indent' },
    { key: 'remove', selector: 'a.delete_item_link', mode: 'remove', label: 'Remove' }
  ];

  function log(...args) {
    if (CONFIG.debug) console.log('[Canvas Bulk]', ...args);
  }

  function $(selector, root = document) {
    return root.querySelector(selector);
  }

  function $$(selector, root = document) {
    return Array.from(root.querySelectorAll(selector));
  }

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function isVisible(el) {
    if (!el) return false;
    const cs = getComputedStyle(el);
    if (cs.display === 'none' || cs.visibility === 'hidden') return false;
    return el.getClientRects().length > 0;
  }

  function debounce(fn, wait) {
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    };
  }

  function getVisibleModules() {
    return $$(SEL.module)
      .filter(isVisible)
      .filter(m => !m.id.endsWith('_blank'));
  }

  function getVisibleItems(moduleEl) {
    return $$(SEL.item, moduleEl)
      .filter(isVisible)
      .filter(li => li.id !== 'context_module_item_blank');
  }

  function getItemRow(itemEl) {
    return $(SEL.itemRow, itemEl);
  }

  function getItemTitle(itemEl) {
    const el = $(SEL.itemTitle, itemEl);
    return (el?.textContent || 'Untitled item').replace(/\s+/g, ' ').trim();
  }

  function getItemType(itemEl) {
    const hiddenType = ($(SEL.itemType, itemEl)?.textContent || '').trim();
    if (hiddenType) return hiddenType;

    const classes = itemEl.classList;
    if (classes.contains('context_module_sub_header')) return 'context_module_sub_header';
    if (classes.contains('external_url')) return 'external_url';
    if (classes.contains('quiz')) return 'quiz';
    if (classes.contains('discussion_topic')) return 'discussion_topic';
    if (classes.contains('wiki_page')) return 'wiki_page';
    if (classes.contains('assignment')) return 'assignment';
    if (classes.contains('attachment')) return 'attachment';
    return '';
  }

  function getItemUrl(itemEl) {
    return ($(SEL.itemUrl, itemEl)?.textContent || '').trim();
  }

  function getItemNewTab(itemEl) {
    return ($(SEL.itemNewTab, itemEl)?.textContent || '').trim() === '1';
  }

  function getSelectedItems(moduleEl) {
    return getVisibleItems(moduleEl).filter(item => {
      const cb = item.querySelector(`.${CLASSES.checkbox}`);
      return !!cb?.checked;
    });
  }

  function getSourceAnchor(itemEl, selector) {
    return itemEl.querySelector(`${SEL.itemMenu} ${selector}`);
  }

  function waitUntil(fn, timeoutMs = 2500, intervalMs = 100) {
    return new Promise(resolve => {
      const end = Date.now() + timeoutMs;
      (function check() {
        if (fn()) return resolve(true);
        if (Date.now() >= end) return resolve(false);
        setTimeout(check, intervalMs);
      })();
    });
  }

  function getCourseId() {
    return (
      window.ENV?.COURSE_ID ||
      window.ENV?.course_id ||
      location.pathname.match(/\/courses\/(\d+)/)?.[1] ||
      ''
    );
  }

  function getModuleId(moduleEl) {
    return (
      moduleEl?.dataset?.moduleId ||
      moduleEl?.id?.match(/context_module_(\d+)/)?.[1] ||
      ''
    );
  }

  function getModuleName(moduleEl) {
    const selectors = [
      '.ig-header-title .name',
      '.context_module_header .name',
      '.header .name',
      '.name',
      '.ig-header-title',
      '.context_module_header'
    ];

    for (const selector of selectors) {
      const el = moduleEl?.querySelector(selector);
      const text = (el?.textContent || '').replace(/\s+/g, ' ').trim();
      if (text) return text;
    }

    return `Module ${getModuleId(moduleEl) || ''}`.trim();
  }

  function getModuleChoices(sourceModuleEl) {
    return getVisibleModules()
      .filter(m => m !== sourceModuleEl)
      .map(m => ({
        moduleEl: m,
        id: getModuleId(m),
        name: getModuleName(m),
        itemCount: getVisibleItems(m).length
      }))
      .filter(x => x.id && x.name);
  }

  function getItemId(itemEl) {
    return itemEl?.id?.match(/context_module_item_(\d+)/)?.[1] || '';
  }

  function getIndentLevel(itemEl) {
    const match = itemEl.className.match(/\bindent_(\d+)\b/);
    return match ? Number(match[1]) : 0;
  }

  function setIndentLevelInDom(itemEl, level) {
    itemEl.className = itemEl.className.replace(/\bindent_\d+\b/g, '').replace(/\s+/g, ' ').trim();
    itemEl.classList.add(`indent_${level}`);
  }

  function canOutdent(itemEl) {
    return getIndentLevel(itemEl) > 0;
  }

  function canIndent(itemEl) {
    return getIndentLevel(itemEl) < 4;
  }

  function canDuplicate(itemEl) {
    const type = getItemType(itemEl);
    if (type === 'quiz' || type === 'external_url' || type === 'context_module_sub_header') return false;
    return !!getSourceAnchor(itemEl, 'a.duplicate_item_link');
  }

  function canMove(itemEl) {
    const moduleEl = itemEl.closest(SEL.module);
    return !!(
      getSourceAnchor(itemEl, 'a.move_module_item_link') &&
      getCourseId() &&
      getModuleId(moduleEl) &&
      getItemId(itemEl)
    );
  }

  function isActionAvailable(itemEl, action) {
    if (action.key === 'move') return canMove(itemEl);
    if (action.key === 'duplicate') return canDuplicate(itemEl);
    if (action.key === 'outdent') return canOutdent(itemEl) && !!getSourceAnchor(itemEl, action.selector);
    if (action.key === 'indent') return canIndent(itemEl) && !!getSourceAnchor(itemEl, action.selector);
    if (action.key === 'remove') return !!getSourceAnchor(itemEl, action.selector);
    return false;
  }

  function getCommonActions(selectedItems) {
    if (!selectedItems.length) return [];
    return ACTIONS.filter(action => selectedItems.every(item => isActionAvailable(item, action)));
  }

  function chooseTargetModule(sourceModuleEl) {
    const targets = getModuleChoices(sourceModuleEl);

    if (!targets.length) {
      alert('No other visible modules were found.');
      return Promise.resolve(null);
    }

    return new Promise(resolve => {
      const existing = document.querySelector(`.${CLASSES.modalOverlay}`);
      if (existing) existing.remove();

      const overlay = document.createElement('div');
      overlay.className = CLASSES.modalOverlay;

      const modal = document.createElement('div');
      modal.className = CLASSES.modal;
      modal.setAttribute('role', 'dialog');
      modal.setAttribute('aria-modal', 'true');
      modal.setAttribute('aria-label', 'Choose destination module');

      const title = document.createElement('div');
      title.className = CLASSES.modalTitle;
      title.textContent = 'Move selected items to…';

      const subtext = document.createElement('div');
      subtext.className = CLASSES.modalSubtext;
      subtext.textContent = 'Choose the module you want to move the selected items into.';

      const list = document.createElement('div');
      list.className = CLASSES.modalList;

      let closed = false;

      const cleanup = () => {
        if (closed) return;
        closed = true;
        overlay.remove();
        document.removeEventListener('keydown', onKeyDown);
      };

      const finish = value => {
        cleanup();
        resolve(value);
      };

      const onKeyDown = e => {
        if (e.key === 'Escape') finish(null);
      };

      targets.forEach(target => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = CLASSES.modalOption;

        const btnTitle = document.createElement('div');
        btnTitle.className = CLASSES.modalOptionTitle;
        btnTitle.textContent = target.name;

        const btnMeta = document.createElement('div');
        btnMeta.className = CLASSES.modalOptionMeta;
        btnMeta.textContent = `${target.itemCount} item${target.itemCount === 1 ? '' : 's'}`;

        btn.appendChild(btnTitle);
        btn.appendChild(btnMeta);

        btn.addEventListener('click', () => finish(target));

        list.appendChild(btn);
      });

      const footer = document.createElement('div');
      footer.className = CLASSES.modalFooter;

      const cancelBtn = document.createElement('button');
      cancelBtn.type = 'button';
      cancelBtn.className = CLASSES.button;
      cancelBtn.textContent = 'Cancel';
      cancelBtn.addEventListener('click', () => finish(null));

      footer.appendChild(cancelBtn);

      modal.appendChild(title);
      modal.appendChild(subtext);
      modal.appendChild(list);
      modal.appendChild(footer);
      overlay.appendChild(modal);
      document.body.appendChild(overlay);

      overlay.addEventListener('click', e => {
        if (e.target === overlay) finish(null);
      });

      document.addEventListener('keydown', onKeyDown);
    });
  }

  function getCSRFToken() {
    return (
      document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ||
      document.querySelector('input[name="authenticity_token"]')?.value ||
      ''
    );
  }

  async function requestWithCSRF(url, method, body = null, extraHeaders = {}) {
    const token = getCSRFToken();

    const headers = {
      'X-CSRF-Token': token,
      'X-Requested-With': 'XMLHttpRequest',
      'Accept': 'application/json, text/javascript, */*; q=0.01',
      ...extraHeaders
    };

    const res = await fetch(url, {
      method,
      credentials: 'same-origin',
      headers,
      body
    });

    if (!res.ok) {
      throw new Error(`${method} failed (${res.status})`);
    }

    return res;
  }

  async function duplicateItemRequest(url) {
    await requestWithCSRF(url, 'POST');
  }

  async function removeItemRequest(url) {
    await requestWithCSRF(url, 'DELETE');
  }

  async function updateIndentRequest(itemEl, url, newIndent) {
    const token = getCSRFToken();
    const body = new URLSearchParams();

    body.set('utf8', '✓');
    body.set('_method', 'put');
    body.set('authenticity_token', token);
    body.set('content_tag[title]', getItemTitle(itemEl));
    body.set('content_tag[indent]', String(newIndent));

    const itemUrl = getItemUrl(itemEl);
    if (itemUrl) {
      body.set('content_tag[url]', itemUrl);
      body.set('content_tag[new_tab]', getItemNewTab(itemEl) ? '1' : '0');
    }

    await requestWithCSRF(
      url,
      'POST',
      body.toString(),
      { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' }
    );
  }

  async function updateModuleItemRequest(sourceModuleId, itemId, params) {
    const courseId = getCourseId();
    if (!courseId) throw new Error('Could not determine course id');

    const body = new URLSearchParams();
    Object.entries(params).forEach(([key, value]) => {
      if (value != null) body.set(key, String(value));
    });

    await requestWithCSRF(
      `/api/v1/courses/${courseId}/modules/${sourceModuleId}/items/${itemId}`,
      'PUT',
      body.toString(),
      { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' }
    );
  }

  async function runDuplicateAction(itemEl) {
    const anchor = getSourceAnchor(itemEl, 'a.duplicate_item_link');
    if (!anchor) throw new Error(`Missing duplicate action for "${getItemTitle(itemEl)}"`);

    await duplicateItemRequest(anchor.href);
    return { reload: true };
  }

  async function runRemoveAction(itemEl) {
    const anchor = getSourceAnchor(itemEl, 'a.delete_item_link');
    if (!anchor) throw new Error(`Missing remove action for "${getItemTitle(itemEl)}"`);

    await removeItemRequest(anchor.href);

    const row = getItemRow(itemEl);
    if (row) row.classList.remove(CLASSES.selectedRow);
    itemEl.remove();

    return { reload: false };
  }

  async function runIndentAction(itemEl, selector) {
    const anchor = getSourceAnchor(itemEl, selector);
    if (!anchor) throw new Error(`Missing indent action for "${getItemTitle(itemEl)}"`);

    const current = getIndentLevel(itemEl);
    const next = selector.includes('outdent') ? Math.max(0, current - 1) : Math.min(3, current + 1);

    if (next === current) return { reload: false };

    await updateIndentRequest(itemEl, anchor.href, next);
    setIndentLevelInDom(itemEl, next);

    return { reload: false };
  }

  async function runMoveAction(itemEl, targetModuleId, targetPosition) {
    const sourceModuleEl = itemEl.closest(SEL.module);
    const sourceModuleId = getModuleId(sourceModuleEl);
    const itemId = getItemId(itemEl);

    if (!sourceModuleId || !itemId) {
      throw new Error(`Missing module/item id for "${getItemTitle(itemEl)}"`);
    }

    await updateModuleItemRequest(sourceModuleId, itemId, {
      'module_item[module_id]': targetModuleId,
      'module_item[position]': targetPosition
    });

    return { reload: true };
  }

  async function runNativeAction(itemEl, action, context = {}) {
    switch (action.mode) {
      case 'move':
        return runMoveAction(itemEl, context.targetModuleId, context.targetPosition);
      case 'duplicate':
        return runDuplicateAction(itemEl);
      case 'remove':
        return runRemoveAction(itemEl);
      case 'indent':
        return runIndentAction(itemEl, action.selector);
      default:
        throw new Error(`Unknown action mode: ${action.mode}`);
    }
  }

  async function runBulkAction(moduleEl, actionKey) {
    const action = ACTIONS.find(a => a.key === actionKey);
    if (!action) return;

    const items = getSelectedItems(moduleEl);
    if (!items.length) return;

    if (!items.every(item => isActionAvailable(item, action))) return;

    let actionContext = {};

    if (action.key === 'remove') {
      const ok = confirm(
        `Remove ${items.length} selected item(s) from this module?\n\n` +
        `This should only remove them from the module, not delete the underlying course content.`
      );
      if (!ok) return;
    }

    if (action.key === 'move') {
      const target = await chooseTargetModule(moduleEl);
      if (!target) return;

      actionContext = {
        targetModuleId: target.id,
        targetModuleName: target.name,
        startPosition: getVisibleItems(target.moduleEl).length + 1
      };
    }

    const failures = [];
    let shouldReload = false;
    let movedCount = 0;

    for (const itemEl of [...items]) {
      try {
        const perItemContext =
          action.key === 'move'
            ? {
                ...actionContext,
                targetPosition: actionContext.startPosition + movedCount
              }
            : actionContext;

        const result = await runNativeAction(itemEl, action, perItemContext);

        if (action.key === 'move') movedCount += 1;
        if (result?.reload) shouldReload = true;
      } catch (err) {
        console.error(err);
        failures.push(`${getItemTitle(itemEl)} — ${err.message}`);
      }

      await sleep(CONFIG.actionDelayMs);
    }

    refreshUI();

    if (failures.length) {
      alert(
        `Finished with ${failures.length} issue(s):\n\n` +
        failures.map(x => `• ${x}`).join('\n')
      );
    }

    if (shouldReload) {
      window.location.reload();
    }
  }

