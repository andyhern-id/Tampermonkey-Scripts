// ==UserScript==
// @name         Canvas Bulk Item Actions (clean toolbar)
// @namespace    https://tampermonkey.net/
// @version      1.0.0
// @description  Bulk actions for Canvas module items with inline toolbar, select all, reliable duplicate/indent/remove.
// @match        https://*/courses/*/modules*
// @match        http://*/courses/*/modules*
// @grant        none
// ==/UserScript==

(function () {
  'use strict';

  const CONFIG = {
    debug: false,
    actionDelayMs: 180
  };

  const SEL = {
    module: '.context_module.item-group-condensed',
    content: '.content',
    itemList: 'ul.context_module_items.manageable, ul.ig-list.items.context_module_items',
    item: 'li.context_module_item',
    itemRow: '.ig-row',
    itemTitle: '.module-item-title .item_name .title, .module-item-title .item_name a, .module-item-title .title',
    itemMenu: '.cog-menu-container .al-options',
    itemType: '.module_item_icons .type',
    itemUrl: '.module-item-title .url',
    itemNewTab: '.module-item-title .new_tab'
  };

  const CLASSES = {
    checkboxCell: 'tm-bulk-checkbox-cell',
    checkbox: 'tm-bulk-checkbox',
    selectedRow: 'tm-bulk-selected-row',
    toolbarWrap: 'tm-bulk-toolbar-wrap',
    toolbar: 'tm-bulk-toolbar',
    button: 'tm-bulk-button',
    buttonDanger: 'tm-bulk-button-danger',
    buttonDisabled: 'tm-bulk-button-disabled',
    count: 'tm-bulk-count',
    hidden: 'tm-bulk-hidden'
  };

  const ACTIONS = [
    { key: 'duplicate', selector: 'a.duplicate_item_link', mode: 'duplicate', label: 'Duplicate' },
    { key: 'outdent', selector: 'a.outdent_item_link', mode: 'indent', label: 'Decrease indent' },
    { key: 'indent', selector: 'a.indent_item_link', mode: 'indent', label: 'Increase indent' },
    { key: 'remove', selector: 'a.delete_item_link', mode: 'remove', label: 'Remove' }
  ];

  function log(...args) {
    if (CONFIG.debug) console.log('[Canvas Bulk]', ...args);
  }

  function $(selector, root = document) {
    return root.querySelector(selector);
  }

  function $$(selector, root = document) {
    return Array.from(root.querySelectorAll(selector));
  }

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function isVisible(el) {
    if (!el) return false;
    const cs = getComputedStyle(el);
    if (cs.display === 'none' || cs.visibility === 'hidden') return false;
    return el.getClientRects().length > 0;
  }

  function debounce(fn, wait) {
    let t = null;
    return (...args) => {
      clearTimeout(t);
      t = setTimeout(() => fn(...args), wait);
    };
  }

  function getVisibleModules() {
    return $$(SEL.module)
      .filter(isVisible)
      .filter(m => !m.id.endsWith('_blank'));
  }

  function getVisibleItems(moduleEl) {
    return $$(SEL.item, moduleEl)
      .filter(isVisible)
      .filter(li => li.id !== 'context_module_item_blank');
  }

  function getItemRow(itemEl) {
    return $(SEL.itemRow, itemEl);
  }

  function getItemTitle(itemEl) {
    const el = $(SEL.itemTitle, itemEl);
    return (el?.textContent || 'Untitled item').replace(/\s+/g, ' ').trim();
  }

  function getItemType(itemEl) {
    const hiddenType = ($(SEL.itemType, itemEl)?.textContent || '').trim();
    if (hiddenType) return hiddenType;

    const classes = itemEl.classList;
    if (classes.contains('context_module_sub_header')) return 'context_module_sub_header';
    if (classes.contains('external_url')) return 'external_url';
    if (classes.contains('quiz')) return 'quiz';
    if (classes.contains('discussion_topic')) return 'discussion_topic';
    if (classes.contains('wiki_page')) return 'wiki_page';
    if (classes.contains('assignment')) return 'assignment';
    if (classes.contains('attachment')) return 'attachment';
    return '';
  }

  function getItemUrl(itemEl) {
    return ($(SEL.itemUrl, itemEl)?.textContent || '').trim();
  }

  function getItemNewTab(itemEl) {
    return ($(SEL.itemNewTab, itemEl)?.textContent || '').trim() === '1';
  }

  function getSelectedItems(moduleEl) {
    return getVisibleItems(moduleEl).filter(item => {
      const cb = item.querySelector(`.${CLASSES.checkbox}`);
      return !!cb?.checked;
    });
  }

  function getSourceAnchor(itemEl, selector) {
    return itemEl.querySelector(`${SEL.itemMenu} ${selector}`);
  }

  function waitUntil(fn, timeoutMs = 2500, intervalMs = 100) {
    return new Promise(resolve => {
      const end = Date.now() + timeoutMs;
      (function check() {
        if (fn()) return resolve(true);
        if (Date.now() >= end) return resolve(false);
        setTimeout(check, intervalMs);
      })();
    });
  }

  function getIndentLevel(itemEl) {
    const match = itemEl.className.match(/\bindent_(\d+)\b/);
    return match ? Number(match[1]) : 0;
  }

  function setIndentLevelInDom(itemEl, level) {
    itemEl.className = itemEl.className.replace(/\bindent_\d+\b/g, '').replace(/\s+/g, ' ').trim();
    itemEl.classList.add(`indent_${level}`);
  }

  function canOutdent(itemEl) {
    return getIndentLevel(itemEl) > 0;
  }

  function canIndent(itemEl) {
    return getIndentLevel(itemEl) < 4;
  }

  function canDuplicate(itemEl) {
    const type = getItemType(itemEl);
    if (type === 'quiz' || type === 'external_url' || type === 'context_module_sub_header') return false;
    return !!getSourceAnchor(itemEl, 'a.duplicate_item_link');
  }

  function isActionAvailable(itemEl, action) {
    if (action.key === 'duplicate') return canDuplicate(itemEl);
    if (action.key === 'outdent') return canOutdent(itemEl) && !!getSourceAnchor(itemEl, action.selector);
    if (action.key === 'indent') return canIndent(itemEl) && !!getSourceAnchor(itemEl, action.selector);
    if (action.key === 'remove') return !!getSourceAnchor(itemEl, action.selector);
    return false;
  }

  function getCommonActions(selectedItems) {
    if (!selectedItems.length) return [];
    return ACTIONS.filter(action => selectedItems.every(item => isActionAvailable(item, action)));
  }

  function getCSRFToken() {
    return (
      document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ||
      document.querySelector('input[name="authenticity_token"]')?.value ||
      ''
    );
  }

  async function requestWithCSRF(url, method, body = null, extraHeaders = {}) {
    const token = getCSRFToken();

    const headers = {
      'X-CSRF-Token': token,
      'X-Requested-With': 'XMLHttpRequest',
      'Accept': 'application/json, text/javascript, */*; q=0.01',
      ...extraHeaders
    };

    const res = await fetch(url, {
      method,
      credentials: 'same-origin',
      headers,
      body
    });

    if (!res.ok) {
      throw new Error(`${method} failed (${res.status})`);
    }

    return res;
  }

  async function duplicateItemRequest(url) {
    await requestWithCSRF(url, 'POST');
  }

  async function removeItemRequest(url) {
    await requestWithCSRF(url, 'DELETE');
  }

  async function updateIndentRequest(itemEl, url, newIndent) {
    const token = getCSRFToken();
    const body = new URLSearchParams();

    body.set('utf8', '✓');
    body.set('_method', 'put');
    body.set('authenticity_token', token);
    body.set('content_tag[title]', getItemTitle(itemEl));
    body.set('content_tag[indent]', String(newIndent));

    const itemUrl = getItemUrl(itemEl);
    if (itemUrl) {
      body.set('content_tag[url]', itemUrl);
      body.set('content_tag[new_tab]', getItemNewTab(itemEl) ? '1' : '0');
    }

    await requestWithCSRF(
      url,
      'POST',
      body.toString(),
      { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' }
    );
  }

  async function runDuplicateAction(itemEl) {
    const anchor = getSourceAnchor(itemEl, 'a.duplicate_item_link');
    if (!anchor) throw new Error(`Missing duplicate action for "${getItemTitle(itemEl)}"`);

    await duplicateItemRequest(anchor.href);
    return { reload: true };
  }

  async function runRemoveAction(itemEl) {
    const anchor = getSourceAnchor(itemEl, 'a.delete_item_link');
    if (!anchor) throw new Error(`Missing remove action for "${getItemTitle(itemEl)}"`);

    await removeItemRequest(anchor.href);

    const row = getItemRow(itemEl);
    if (row) row.classList.remove(CLASSES.selectedRow);
    itemEl.remove();

    return { reload: false };
  }

  async function runIndentAction(itemEl, selector) {
    const anchor = getSourceAnchor(itemEl, selector);
    if (!anchor) throw new Error(`Missing indent action for "${getItemTitle(itemEl)}"`);

    const current = getIndentLevel(itemEl);
    const next = selector.includes('outdent') ? Math.max(0, current - 1) : Math.min(3, current + 1);

    if (next === current) return { reload: false };

    await updateIndentRequest(itemEl, anchor.href, next);
    setIndentLevelInDom(itemEl, next);

    return { reload: false };
  }

  async function runNativeAction(itemEl, action) {
    switch (action.mode) {
      case 'duplicate':
        return runDuplicateAction(itemEl);
      case 'remove':
        return runRemoveAction(itemEl);
      case 'indent':
        return runIndentAction(itemEl, action.selector);
      default:
        throw new Error(`Unknown action mode: ${action.mode}`);
    }
  }

  async function runBulkAction(moduleEl, actionKey) {
    const action = ACTIONS.find(a => a.key === actionKey);
    if (!action) return;

    const items = getSelectedItems(moduleEl);
    if (!items.length) return;

    if (!items.every(item => isActionAvailable(item, action))) return;

    if (action.key === 'remove') {
      const ok = confirm(`Remove ${items.length} selected item(s) from this module?\n\nThis should only remove them from the module, not delete the underlying course content.`);
      if (!ok) return;
    }

    const failures = [];
    let shouldReload = false;

    for (const itemEl of [...items]) {
      try {
        const result = await runNativeAction(itemEl, action);
        if (result?.reload) shouldReload = true;
      } catch (err) {
        console.error(err);
        failures.push(`${getItemTitle(itemEl)} — ${err.message}`);
      }

      await sleep(CONFIG.actionDelayMs);
    }

    refreshUI();

    if (failures.length) {
      alert(
        `Finished with ${failures.length} issue(s):\n\n` +
        failures.map(x => `• ${x}`).join('\n')
      );
    }

    if (shouldReload) {
      window.location.reload();
    }
  }

  function injectStyles() {
    if (document.getElementById('tm-bulk-style')) return;

    const style = document.createElement('style');
    style.id = 'tm-bulk-style';
    style.textContent = `
      .${CLASSES.checkboxCell} {
        width: 26px;
        min-width: 26px;
        max-width: 26px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 26px;
        margin-right: 2px;
      }

      .${CLASSES.checkbox} {
        width: 15px;
        height: 15px;
        margin: 0;
        cursor: pointer;
      }

      .context_module_item .ig-row.${CLASSES.selectedRow} {
        background: rgba(17,45,84,0.05) !important;
        box-shadow: inset 4px 0 0 #08a650;
      }

      .${CLASSES.toolbarWrap} {
        margin: 0 10px 0 6px;
        padding: 12px 0 10px;
        border-top: 1px solid #c7cdd1;
      }

      .${CLASSES.toolbar} {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .${CLASSES.button} {
        appearance: none;
        border: 1px solid #c7cdd1;
        background: #fff;
        color: #2d3b45;
        border-radius: 999px;
        min-height: 38px;
        padding: 0 16px;
        font-size: 14px;
        line-height: 1;
        cursor: pointer;
        box-sizing: border-box;
      }

      .${CLASSES.button}:hover:not(.${CLASSES.buttonDisabled}) {
        background: #f8f9fa;
      }

      .${CLASSES.buttonDanger} {
        border-color: #d9b8b8;
        color: #8a3c38;
      }

      .${CLASSES.buttonDisabled} {
        background: #f8f9fa !important;
        color: #9aa4af !important;
        border-color: #d8dde3 !important;
        cursor: not-allowed !important;
      }

      .${CLASSES.count} {
        display: inline-flex;
        align-items: center;
        border: 1px solid #c7cdd1;
        background: #fff;
        color: #2d3b45;
        border-radius: 999px;
        min-height: 38px;
        padding: 0 16px;
        font-size: 14px;
        line-height: 1;
        box-sizing: border-box;
        white-space: nowrap;
      }

      .${CLASSES.hidden} {
        display: none !important;
      }
    `;
    document.head.appendChild(style);
  }

  function ensureCheckbox(itemEl) {
    if (itemEl.dataset.tmBulkReady === '1') return;
    itemEl.dataset.tmBulkReady = '1';

    const row = getItemRow(itemEl);
    if (!row) return;

    const handle = row.querySelector('.ig-handle');

    const cell = document.createElement('div');
    cell.className = CLASSES.checkboxCell;

    const cb = document.createElement('input');
    cb.type = 'checkbox';
    cb.className = CLASSES.checkbox;
    cb.title = `Select ${getItemTitle(itemEl)}`;

    cb.addEventListener('change', () => {
      row.classList.toggle(CLASSES.selectedRow, cb.checked);
      const moduleEl = itemEl.closest(SEL.module);
      if (moduleEl) updateToolbarState(moduleEl);
    });

    cell.appendChild(cb);

    if (handle && handle.nextSibling) {
      row.insertBefore(cell, handle.nextSibling);
    } else {
      row.insertBefore(cell, row.firstChild);
    }
  }

  function setItemChecked(itemEl, checked) {
    const cb = itemEl.querySelector(`.${CLASSES.checkbox}`);
    const row = getItemRow(itemEl);
    if (!cb || !row) return;
    cb.checked = checked;
    row.classList.toggle(CLASSES.selectedRow, checked);
  }

  function clearSelections(moduleEl) {
    getVisibleItems(moduleEl).forEach(item => setItemChecked(item, false));
    updateToolbarState(moduleEl);
  }

  function selectAllItems(moduleEl) {
    getVisibleItems(moduleEl).forEach(item => setItemChecked(item, true));
    updateToolbarState(moduleEl);
  }

  function ensureToolbar(moduleEl) {
    const content = $(SEL.content, moduleEl);
    const list = $(SEL.itemList, moduleEl);
    if (!content || !list) return null;

    let wrap = content.querySelector(`.${CLASSES.toolbarWrap}`);
    if (wrap) return wrap;

    wrap = document.createElement('div');
    wrap.className = `${CLASSES.toolbarWrap} ${CLASSES.hidden}`;

    const toolbar = document.createElement('div');
    toolbar.className = CLASSES.toolbar;
    toolbar.setAttribute('role', 'toolbar');
    toolbar.setAttribute('aria-label', 'Bulk item actions');

    const makeButton = (label, attrs = {}) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = CLASSES.button;
      btn.textContent = label;
      Object.entries(attrs).forEach(([k, v]) => btn.setAttribute(k, v));
      return btn;
    };

    const selectAllBtn = makeButton('Select All', { 'data-bulk-control': 'select-all' });
    selectAllBtn.addEventListener('click', () => selectAllItems(moduleEl));

    toolbar.appendChild(selectAllBtn);

    ACTIONS.forEach(action => {
      const btn = makeButton(action.label, { 'data-bulk-action': action.key });
      if (action.key === 'remove') btn.classList.add(CLASSES.buttonDanger);

      btn.addEventListener('click', () => {
        if (btn.disabled) return;
        runBulkAction(moduleEl, action.key);
      });

      toolbar.appendChild(btn);
    });

    const clearBtn = makeButton('Unselect All', { 'data-bulk-control': 'clear' });
    clearBtn.addEventListener('click', () => clearSelections(moduleEl));
    toolbar.appendChild(clearBtn);

    const count = document.createElement('span');
    count.className = CLASSES.count;
    toolbar.appendChild(count);

    wrap.appendChild(toolbar);
    content.insertBefore(wrap, list);

    return wrap;
  }

  function updateToolbarState(moduleEl) {
    const wrap = ensureToolbar(moduleEl);
    if (!wrap) return;

    const selectedItems = getSelectedItems(moduleEl);
    const count = selectedItems.length;
    const totalItems = getVisibleItems(moduleEl).length;
    const commonActions = getCommonActions(selectedItems);

    wrap.classList.toggle(CLASSES.hidden, count === 0);

    const countEl = wrap.querySelector(`.${CLASSES.count}`);
    const clearBtn = wrap.querySelector('[data-bulk-control="clear"]');
    const selectAllBtn = wrap.querySelector('[data-bulk-control="select-all"]');

    if (countEl) {
      countEl.textContent = `${count} selected`;
    }

    if (clearBtn) {
      clearBtn.classList.toggle(CLASSES.hidden, count === 0);
    }

    if (selectAllBtn) {
      const hideSelectAll = count === 0 || totalItems === 0 || count === totalItems;
      selectAllBtn.classList.toggle(CLASSES.hidden, hideSelectAll);
      selectAllBtn.disabled = hideSelectAll;
      selectAllBtn.classList.toggle(CLASSES.buttonDisabled, selectAllBtn.disabled);
    }

    wrap.querySelectorAll('[data-bulk-action]').forEach(btn => {
      const action = ACTIONS.find(a => a.key === btn.dataset.bulkAction);
      const enabled = count > 0 && commonActions.some(a => a.key === action.key);
      btn.disabled = !enabled;
      btn.classList.toggle(CLASSES.buttonDisabled, !enabled);
    });
  }

  function refreshUI() {
    getVisibleModules().forEach(moduleEl => {
      getVisibleItems(moduleEl).forEach(ensureCheckbox);
      ensureToolbar(moduleEl);
      updateToolbarState(moduleEl);
    });
  }

  function init() {
    injectStyles();
    refreshUI();

    const observer = new MutationObserver(debounce(() => {
      refreshUI();
    }, 120));

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

    log('Initialized');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
